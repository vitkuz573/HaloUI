@inherits ThemeAwareInputText

<HaloTextField @attributes="AdditionalAttributes"
             Label="@Label"
             Class="halo-password-field"
             Spellcheck="false"
             @bind-value="CurrentValue"
             Type="@(_showPassword ? TextFieldType.Text : TextFieldType.Password)">
    <EndAdornment>
        <button type="button"
                class="halo-password-field__toggle"
                @onclick="TogglePasswordVisibility"
                aria-label="@(_showPassword ? "Hide password" : "Show password")"
                aria-pressed="@_showPassword">
            <HaloIcon Name="@(_showPassword ? HaloDefaultIcons.VisibilityOff : HaloDefaultIcons.Visibility)" Class="halo-password-field__toggle-icon" Decorative="true" />
        </button>
    </EndAdornment>
</HaloTextField>
