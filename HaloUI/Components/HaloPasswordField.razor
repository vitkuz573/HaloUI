@using HaloUI.Theme
@using HaloUI.Theme.Tokens.Component

@inherits ThemeAwareInputText

<HaloTextField @attributes="AdditionalAttributes"
             Label="@Label"
             Spellcheck="false"
             @bind-value="CurrentValue"
             Type="@(_showPassword ? TextFieldType.Text : TextFieldType.Password)">
    <EndAdornment>
        <button type="button"
                style="@BuildButtonStyle()"
                @onclick="TogglePasswordVisibility"
                aria-label="@(_showPassword ? "Hide password" : "Show password")"
                aria-pressed="@_showPassword">
            <span class="material-icons" style="font-size:@Tokens.AdornmentSize" aria-hidden="true">@(_showPassword ? "visibility_off" : "visibility")</span>
        </button>
    </EndAdornment>
</HaloTextField>
