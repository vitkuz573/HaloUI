@typeparam TValue

<div class="halo-radio-group @(Segmented ? "halo-radio-group--segmented" : "halo-radio-group--standard") @Class"
     @attributes="BuildGroupAttributes()">
    <CascadingValue Value="this">
        @if (Segmented)
        {
            <div class="halo-radio-group__segments @SegmentClass">
                @ChildContent
            </div>
        }
        else
        {
            <div class="halo-radio-group__stack @SegmentClass">
                @ChildContent
            </div>
        }
    </CascadingValue>
</div>
