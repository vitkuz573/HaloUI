@using Microsoft.Extensions.Logging
@using HaloUI.Theme
@using HaloUI.Theme.Tokens.Component

@inject ISnackbarService Snackbar
@inject ILogger<SnackbarHost> Logger

<div class="halo-snackbar-stack" style="@StackPositionStyle">
    @foreach (var item in _items)
    {
        <div @key="item.Id"
             class="@BuildContainerClass(item)"
             role="status"
             aria-live="polite"
             aria-label="@GetAccessibleLabel(item)"
             style="@BuildContainerStyle(item)"
             @onpointerenter="() => OnSnackbarPointerEnterAsync(item)"
             @onpointerleave="() => OnSnackbarPointerLeaveAsync(item)">
            <div class="halo-snackbar__body">
                <div class="halo-snackbar__header">
                    <div class="halo-snackbar__title">
                        <HaloIcon Name="@GetIcon(item.Severity)" Class="halo-snackbar__icon" Decorative="true" />
                        <span>@GetDisplayTitle(item)</span>
                    </div>
                    <div class="halo-snackbar__actions">
                        @if (item.Action is not null)
                        {
                            <button class="halo-snackbar__action"
                                    type="button"
                                    @onclick:stopPropagation="true"
                                    @onclick="@(() => HandleActionAsync(item))">
                                @item.Action.Text
                            </button>
                        }
                        <button class="halo-snackbar__dismiss"
                                type="button"
                                title="Dismiss"
                                aria-label="Dismiss notification"
                                @onclick:stopPropagation="true"
                                @onclick="@(() => Dismiss(item.Id))">
                            <HaloIcon Name="@HaloDefaultIcons.Close" Decorative="true" />
                        </button>
                    </div>
                </div>
                <div class="halo-snackbar__message">@item.Text</div>
                @if (item.DurationMs > 0)
                {
                    <div class="halo-snackbar__progress">
                        <div class="@BuildProgressBarClass(item)"
                             style="@BuildProgressBarStyle(item)"></div>
                        
                    </div>
                }
            </div>
        </div>
    }
</div>
