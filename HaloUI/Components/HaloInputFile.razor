@using Microsoft.AspNetCore.Components.Forms

<div class="@BuildWrapperClass()" @attributes="BuildRootAttributes()">
    @if (Mode != HaloInputFileMode.Hidden && !string.IsNullOrWhiteSpace(Label))
    {
        <HaloLabel Id="@LabelElementId"
                   For="@InputId"
                   Text="@Label"
                   Variant="@ResolveLabelVariant()"
                   Disabled="@Disabled"
                   ShowRequiredIndicator="@Required" />
    }

    <div class="@BuildControlClass()">
        <InputFile @key="_inputRenderKey"
                   @ref="_inputFile"
                   id="@InputId"
                   class="@BuildInputClass()"
                   OnChange="HandleChangeAsync"
                   @attributes="BuildInputAttributes()" />

        @if (Mode == HaloInputFileMode.Inline)
        {
            <label class="@BuildTriggerClass()" for="@InputId" aria-disabled="@(Disabled ? "true" : "false")">
                <span class="halo-inputfile__trigger-text">@ResolveBrowseText()</span>
            </label>
        }

        @if (Mode == HaloInputFileMode.Dropzone)
        {
            <label class="@BuildTriggerClass()" for="@InputId" aria-disabled="@(Disabled ? "true" : "false")">
                <span class="halo-inputfile__dropzone-title">@ResolveDropzoneTitleText()</span>
                <span class="halo-inputfile__dropzone-hint">@ResolveDropzoneHintText()</span>
            </label>
        }

        @if (Mode != HaloInputFileMode.Hidden && ShowSummary)
        {
            <span id="@SummaryElementId" class="@BuildSummaryClass()" aria-live="polite">@BuildSummaryText()</span>
        }

        @if (Mode != HaloInputFileMode.Hidden && ShowClearButton && HasFiles && !Disabled)
        {
            <button type="button" class="halo-inputfile__clear" @onclick="ClearAsync">@ClearText</button>
        }
    </div>

    @if (Mode != HaloInputFileMode.Hidden && ShowFileList && HasFiles)
    {
        <ul class="@BuildListClass()">
            @foreach (var file in GetVisibleFiles())
            {
                <li class="halo-inputfile__item">
                    <span class="halo-inputfile__item-name">@file.Name</span>

                    @if (ShowFileSize)
                    {
                        <span class="halo-inputfile__item-size">@FormatFileSize(file.Size)</span>
                    }
                </li>
            }

            @if (HiddenFileCount > 0)
            {
                <li class="halo-inputfile__item halo-inputfile__item--more">+@HiddenFileCount more</li>
            }
        </ul>
    }

    @if (Mode != HaloInputFileMode.Hidden && ShowRejections && HasRejections)
    {
        <ul class="halo-inputfile__rejections">
            @foreach (var rejection in Rejections)
            {
                <li class="halo-inputfile__rejection">@rejection.Message</li>
            }
        </ul>
    }

    @if (Mode != HaloInputFileMode.Hidden && !string.IsNullOrWhiteSpace(Description))
    {
        <p id="@DescriptionElementId" class="halo-inputfile__description">@Description</p>
    }
</div>
