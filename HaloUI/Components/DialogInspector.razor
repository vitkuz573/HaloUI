@using System
@using System.Collections.Generic
@using System.Globalization
@using System.Linq
@using Microsoft.Extensions.Options
@using HaloUI.Abstractions
@using HaloUI.Services

@inject IDialogDiagnosticsHub DiagnosticsHub
@inject DialogInspectorState InspectorState
@inject IOptions<DialogInspectorOptions>? InspectorOptionsAccessor

@if (_isVisible)
{
    <div class="halo-di">
        <header class="halo-di__header">
            <div class="halo-di__top">
                <div class="halo-di__titles">
                    <span class="halo-di__title">Dialog Inspector</span>
                    <span class="halo-di__status">@HeaderStatus</span>
                    <div class="halo-di__badges">
                        @if (_preferences.IsPinned)
                        {
                            <span class="halo-di-badge halo-di-badge--pinned">Pinned</span>
                        }
                        @if (_preferences.IsLogPaused)
                        {
                            <span class="halo-di-badge halo-di-badge--paused">Paused</span>
                        }
                        @if (AnyFilters)
                        {
                            <span class="halo-di-badge halo-di-badge--filters">Filters</span>
                        }
                    </div>
                </div>

                <div class="halo-di__actions">
                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Secondary"
                              Density="ButtonDensity.Compact"
                              Activated="TogglePin">
                        @(_preferences.IsPinned ? "Unpin" : "Pin")
                    </HaloButton>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Warning"
                              Density="ButtonDensity.Compact"
                              Activated="ToggleLogPause">
                        @(_preferences.IsLogPaused ? "Resume" : "Pause")
                    </HaloButton>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Danger"
                              Density="ButtonDensity.Compact"
                              Activated="DismissAll">
                        Dismiss All
                    </HaloButton>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Ghost"
                              Density="ButtonDensity.Compact"
                              Icon="@HaloDefaultIcons.Close"
                              IconOnly="true"
                              AriaLabel="Close inspector"
                              Activated="Hide" />
                </div>
            </div>

            <div class="halo-di__search-row">
                <div class="halo-di__search">
                    <HaloTextField Type="TextFieldType.Search"
                                 Size="InputFieldSize.Small"
                                 Placeholder="Search title, principal, id, metadata…"
                                 Value="@_preferences.SearchTerm"
                                 UpdateBehavior="TextFieldUpdateBehavior.OnInput"
                                 InputChanged="HandleSearchInput" />
                </div>

                <div class="halo-di__view-switch">
                    <span class="halo-di__view-label">View</span>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Secondary"
                              Density="ButtonDensity.Compact"
                              Toggle="true"
                              Active="@(_preferences.ViewMode == InspectorViewMode.Activity)"
                              Activated="() => SetViewMode(InspectorViewMode.Activity)">
                        Activity
                    </HaloButton>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Danger"
                              Density="ButtonDensity.Compact"
                              Toggle="true"
                              Active="@(_preferences.ViewMode == InspectorViewMode.AccessDenied)"
                              Activated="() => SetViewMode(InspectorViewMode.AccessDenied)">
                        Denials
                    </HaloButton>
                </div>
            </div>

            @if (_preferences.ViewMode == InspectorViewMode.Activity)
            {
                <div class="halo-di__filters">
                    <HaloToggle Size="ToggleSize.Small"
                              Checked="@_preferences.ShowOnlyCancelled"
                              CheckedChanged="HandleCancelledFilterChanged"
                              Label="Cancelled only" />

                    <HaloToggle Size="ToggleSize.Small"
                              Checked="@(_options.CaptureMetadata && _preferences.ShowMetadata)"
                              Disabled="@(!_options.CaptureMetadata)"
                              CheckedChanged="HandleMetadataToggle"
                              Label="Metadata" />

                    <HaloToggle Size="ToggleSize.Small"
                              Checked="@_preferences.ShowContext"
                              CheckedChanged="HandleContextToggle"
                              Label="Context" />

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Secondary"
                              Density="ButtonDensity.Compact"
                              Activated="ClearCurrentFilters"
                              Disabled="@(!HasCurrentFilters)">
                        Clear
                    </HaloButton>
                </div>

                @if (PendingEventCount > 0)
                {
                    <div class="halo-di__queue-banner">
                        <span>@PendingEventCount event(s) queued while capture is paused.</span>

                        <HaloButton Size="ButtonSize.ExtraSmall"
                                  Variant="ButtonVariant.Warning"
                                  Density="ButtonDensity.Compact"
                                  Activated="() => FlushPendingEvents(force: true)"
                                  Disabled="@_preferences.IsLogPaused">
                            Process queued
                        </HaloButton>
                    </div>
                }
            }
            else
            {
                <div class="halo-di__access-filters">
                    <div class="halo-di-field-group halo-di-field-group--reason">
                        <span>Reason</span>
                        <HaloSelect TValue="DialogAccessDeniedReason?"
                                  Size="InputFieldSize.Small"
                                  Value="@_preferences.AccessReasonFilter"
                                  ValueChanged="HandleAccessReasonChanged"
                                  EnumBehavior="@(new HaloUI.Components.Select.HaloSelectEnumBehavior<DialogAccessDeniedReason?> { Enabled = true, IncludeNullOption = true, NullOptionText = "All" })" />
                    </div>

                    <div class="halo-di-field-group halo-di-field-group--role">
                        <span>Role filter</span>
                        <HaloTextField Type="TextFieldType.Search"
                                     Size="InputFieldSize.Small"
                                     Value="@_preferences.RoleFilter"
                                     UpdateBehavior="TextFieldUpdateBehavior.OnInput"
                                     InputChanged="HandleRoleFilterChanged"
                                     Placeholder="e.g. Administrator" />
                    </div>

                    <HaloButton Size="ButtonSize.ExtraSmall"
                              Variant="ButtonVariant.Danger"
                              Density="ButtonDensity.Compact"
                              Activated="ClearCurrentFilters"
                              Disabled="@(!HasCurrentFilters)">
                        Clear
                    </HaloButton>
                </div>
            }
        </header>

        <div class="halo-di__content">
            <section class="halo-di__sessions">
                @if (_activeSessions.Count == 0)
                {
                    <div class="halo-di-state">
                        No dialogs are currently active.
                    </div>
                }
                else
                {
                    <ul class="halo-di-session-list">
                        @foreach (var session in _activeSessions)
                        {
                            <li class="halo-di-session-card">
                                <div class="halo-di-session-card__header">
                                    <div class="halo-di-session-card__identity">
                                        <span class="halo-di-session-card__title">@session.Title</span>
                                        <span class="halo-di-session-card__id">@session.Id</span>
                                    </div>

                                    <div class="halo-di-session-card__meta">
                                        <span>@FormatTimestamp(session.CreatedAt)</span>
                                        <span>↑ @FormatDuration(session.CreatedAt)</span>

                                        <HaloButton Size="ButtonSize.ExtraSmall"
                                                  Variant="ButtonVariant.Danger"
                                                  Density="ButtonDensity.Compact"
                                                  Activated="() => Dismiss(session.Id)">
                                            Dismiss
                                        </HaloButton>
                                    </div>
                                </div>

                                <div class="halo-di-session-card__details">
                                    <div class="halo-di-detail">Size: <span class="halo-di-value">@session.Options.Size</span></div>
                                    <div class="halo-di-detail">
                                        Presentation:
                                        <span class="halo-di-value">@session.Options.Variant.Presentation</span>
                                        @if (session.Options.Variant is DialogDrawerOptions drawerVariant)
                                        {
                                            <span class="halo-di-subvalue">
                                                (@drawerVariant.Placement@if (!string.IsNullOrWhiteSpace(drawerVariant.Width)){<text>, @drawerVariant.Width</text>})
                                            </span>
                                        }
                                    </div>
                                    <div class="halo-di-detail">
                                        CloseOnEscape: <span class="halo-di-value">@session.Options.CloseOnEscape</span> ·
                                        CloseOnOverlayClick: <span class="halo-di-value">@session.Options.CloseOnOverlayClick</span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(session.Options.CssClass))
                                    {
                                        <div class="halo-di-detail">CssClass: <span class="halo-di-value">@session.Options.CssClass</span></div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(session.Options.InitialFocusElementId))
                                    {
                                        <div class="halo-di-detail">InitialFocus: <span class="halo-di-value">@session.Options.InitialFocusElementId</span></div>
                                    }
                                </div>

                                @if (ShouldShowMetadata(session))
                                {
                                    <div class="halo-di-kv-panel">
                                        <span class="halo-di-kv-panel__title">Metadata</span>
                                        @foreach (var item in EnumerateMetadata(session.Metadata))
                                        {
                                            <div class="halo-di-kv-row">
                                                <span class="halo-di-kv-key">@item.Key</span>
                                                <span class="halo-di-kv-value">@item.Value</span>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (ShouldShowContext(session))
                                {
                                    <div class="halo-di-kv-panel">
                                        <span class="halo-di-kv-panel__title">Context</span>
                                        @foreach (var (label, value) in EnumerateContext(session.Context))
                                        {
                                            <div class="halo-di-kv-row">
                                                <span class="halo-di-kv-key">@label</span>
                                                <span class="halo-di-kv-value">@value</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="halo-di__events">
                <div class="halo-di__events-header">
                    <span class="halo-di__events-title">@(_preferences.ViewMode == InspectorViewMode.Activity ? "Activity log" : "Access denials")</span>
                    <span class="halo-di__events-summary">
                        @(_preferences.ViewMode switch
                        {
                            InspectorViewMode.Activity => GetActivityLogSummary(),
                            InspectorViewMode.AccessDenied => GetAccessDenialSummary(),
                            _ => string.Empty
                        })
                    </span>
                </div>

                @if (_preferences.ViewMode == InspectorViewMode.Activity)
                {
                    var activityEntries = GetFilteredActivityEvents().ToArray();

                    @if (activityEntries.Length == 0)
                    {
                        <div class="halo-di-state halo-di-state--compact">
                            @(HasActivityFilters ? "No events match the current filters." : "Awaiting activity…")
                        </div>
                    }
                    else
                    {
                        <ul class="halo-di-log-list">
                            @foreach (var entry in activityEntries)
                            {
                                <li class="@GetActivityEntryClass(entry)">
                                    <div class="halo-di-log-entry__body">
                                        <span class="halo-di-log-entry__title">@entry.Title</span>
                                        <span class="halo-di-log-entry__description">@entry.EventDescription</span>

                                        @if (!string.IsNullOrWhiteSpace(entry.Principal))
                                        {
                                            <span class="halo-di-log-entry__meta">Principal · @entry.Principal</span>
                                        }

                                        @if (_preferences.ShowContext && entry.Context.HasContextData)
                                        {
                                            <span class="halo-di-log-entry__meta">
                                                @string.Join(" · ", EnumerateContext(entry.Context).Take(2).Select(tuple => $"{tuple.Label}: {tuple.Value}"))
                                            </span>
                                        }

                                        @if (_preferences.ShowMetadata && _options.CaptureMetadata && entry.HasMetadata)
                                        {
                                            <span class="halo-di-log-entry__meta">
                                                @string.Join(" · ", EnumerateMetadata(entry.Metadata).Take(2).Select(pair => $"{pair.Key}: {pair.Value}"))
                                            </span>
                                        }
                                    </div>

                                    <div class="halo-di-log-entry__stamp">
                                        <span>@FormatTimestamp(entry.Timestamp)</span>
                                        <span>@entry.DialogId</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                }
                else
                {
                    var denialEntries = GetFilteredAccessEvents().ToArray();

                    @if (denialEntries.Length == 0)
                    {
                        <div class="halo-di-state halo-di-state--compact halo-di-state--danger">
                            @(HasAccessFilters ? "No access denials match the current filters." : "No access denials recorded.")
                        </div>
                    }
                    else
                    {
                        <ul class="halo-di-log-list">
                            @foreach (var entry in denialEntries)
                            {
                                <li class="halo-di-log-entry halo-di-log-entry--denied">
                                    <div class="halo-di-log-entry__body">
                                        <span class="halo-di-log-entry__title">@entry.Title</span>
                                        <span class="halo-di-log-entry__description">@entry.EventDescription</span>

                                        @if (!string.IsNullOrWhiteSpace(entry.Principal))
                                        {
                                            <span class="halo-di-log-entry__meta">Principal · @entry.Principal</span>
                                        }

                                        @if (entry.MissingRoles?.Any() == true)
                                        {
                                            <span class="halo-di-log-entry__meta">Missing roles · @string.Join(", ", entry.MissingRoles!)</span>
                                        }
                                    </div>

                                    <div class="halo-di-log-entry__stamp">
                                        <span>@FormatTimestamp(entry.Timestamp)</span>
                                        <span>@entry.DialogId</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                }
            </section>
        </div>
    </div>
}
