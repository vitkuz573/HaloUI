<div class="@RootClass" @attributes="AdditionalAttributes">
    @if (BackgroundOverlay is not null)
    {
        <div class="halo-layout__background">
            @BackgroundOverlay
        </div>
    }

    <div class="halo-layout__shell">
        @if (ShouldRenderOverlay)
        {
            <button type="button"
                    class="halo-layout__backdrop"
                    aria-label="@OverlayCloseLabel"
                    @onclick="HandleOverlayCloseAsync"></button>
        }

        @if (Navigation is not null)
        {
            <aside class="@NavigationContainerClass" @attributes="NavigationAttributes">
                @Navigation
            </aside>
        }

        <div class="@MainContainerClass" @attributes="MainAttributes">
            @if (Header is not null)
            {
                <header class="@HeaderContainerClass">
                    @Header
                </header>
            }

            @if (Toolbar is not null)
            {
                <div class="@ToolbarContainerClass">
                    @Toolbar
                </div>
            }

            <main class="@ContentContainerClass">
                @ChildContent
            </main>

            @if (Footer is not null)
            {
                <footer class="@FooterContainerClass">
                    @Footer
                </footer>
            }
        </div>

        @if (Notification is not null)
        {
            <aside class="@NotificationContainerClass" @attributes="NotificationAttributes">
                @Notification
            </aside>
        }
    </div>
</div>
