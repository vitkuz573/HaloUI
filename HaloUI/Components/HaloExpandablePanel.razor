@using Microsoft.JSInterop

@inject IJSRuntime JsRuntime

<section class="@BuildContainerClass()" id="@Id" @attributes="BuildContainerAttributes()">
    @if (HeaderContent is not null)
    {
        <div class="halo-expandable-panel__header">
            @HeaderContent
        </div>
    }
    else
    {
        <div class="halo-expandable-panel__header">
            <button type="button"
                    id="@_headerButtonId"
                    class="@BuildHeaderButtonClass()"
                    disabled="@Disabled"
                    aria-expanded="@_expanded"
                    aria-controls="@_contentId"
                    aria-disabled="@(Disabled ? "true" : null)"
                    @onclick="ToggleAsync">
                @if (Prefix is not null)
                {
                    <span class="halo-expandable-panel__prefix">
                        @Prefix
                    </span>
                }
                else if (Icon is not null)
                {
                    <span class="halo-expandable-panel__prefix">
                        <HaloIcon Name="@Icon" Class="halo-expandable-panel__prefix-icon" Decorative="true" />
                    </span>
                }

                <div class="halo-expandable-panel__header-content">
                    <div class="halo-expandable-panel__title-row">
                        @if (!string.IsNullOrWhiteSpace(Title))
                        {
                            <span class="halo-expandable-panel__title">@Title</span>
                        }
                        @if (Metadata is not null)
                        {
                            <span class="halo-expandable-panel__metadata">@Metadata</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Subtitle))
                    {
                        <span class="halo-expandable-panel__subtitle">@Subtitle</span>
                    }
                    else if (Description is not null)
                    {
                        <div class="halo-expandable-panel__description">@Description</div>
                    }
                </div>

                <HaloIcon Name="@HaloDefaultIcons.ExpandMore" Class="@BuildIndicatorClass()" Decorative="true" />
            </button>

            @if (Actions is not null)
            {
                <div class="halo-expandable-panel__actions">
                    @Actions
                </div>
            }
        </div>
    }

    <div id="@_contentId"
         class="halo-expandable-panel__content @( _expanded ? "is-expanded" : string.Empty )"
         role="@GetContentRegionRole()"
         aria-labelledby="@ResolveContentLabelledBy()"
         aria-label="@ResolveContentAriaLabel()"
         aria-describedby="@ResolveContentDescribedBy()"
         aria-hidden="@((!_expanded).ToString().ToLowerInvariant())"
         style="@BuildContentStyle()">
        @if ((_expanded || _hasRenderedBody) && ChildContent is not null)
        {
            <div class="halo-expandable-panel__body">
                @ChildContent
            </div>
        }

        @if ((_expanded || _hasRenderedFooter) && Footer is not null)
        {
            <div class="halo-expandable-panel__footer">
                @Footer
            </div>
        }
    </div>
</section>
