      "requiredStateSelectors": [
        "[role=\"slider\"]"
      ]
    },
    {
      "id": "toggles",
      "heading": "Toggles",
      "presenceSelector": "[role=\"switch\"]",
      "focusSelector": "[role=\"switch\"]",
      "requiredStateSelectors": [
        "[role=\"switch\"]"
      ]
    },
    {
      "id": "tri-state",
      "heading": "Tri State",
      "presenceSelector": "[role=\"checkbox\"]",
      "focusSelector": "[role=\"checkbox\"]",
      "requiredStateSelectors": [
        "[role=\"checkbox\"]"
      ]
    },
    {
      "id": "radio-group",
      "heading": "Radio Group",
      "presenceSelector": "[role=\"radio\"]",
      "focusSelector": "[role=\"radio\"]",
      "requiredStateSelectors": [
        "[role=\"radio\"]"
      ]
