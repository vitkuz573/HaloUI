  "demoSections": [
    {
      "id": "buttons",
      "heading": "Buttons",
      "presenceSelector": "[data-testid=\"button-primary-action\"]",
      "focusSelector": "button",
      "requiredStateSelectors": [
        "[data-testid=\"button-primary-action\"]",
        "[data-testid=\"button-secondary-action\"]",
        "[data-testid=\"button-warning-action\"]"
      ]
    },
    {
      "id": "button-density",
      "heading": "Button Density",
      "presenceSelector": "button",
      "focusSelector": "button",
      "requiredStateSelectors": [
        "button"
      ]
    },
    {
      "id": "text-fields",
      "heading": "Text Fields",
      "presenceSelector": "input[type=\"text\"]",
      "focusSelector": "input[type=\"text\"]",
      "requiredStateSelectors": [
        "input[type=\"text\"]:not([disabled])",
        "input[type=\"text\"][disabled]"
      ]
    },
    {
      "id": "password",
      "heading": "Password",
      "presenceSelector": "input[type=\"password\"], input[type=\"text\"]",
      "focusSelector": "input",
      "requiredStateSelectors": [
        "input[type=\"password\"], input[type=\"text\"]"
      ]
    },
    {
      "id": "text-area",
      "heading": "Text Area",
      "presenceSelector": "textarea",
      "focusSelector": "textarea",
      "requiredStateSelectors": [
        "textarea"
      ]
    },
    {
      "id": "select",
